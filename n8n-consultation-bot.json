{
  "name": "MIK Consultation → Telegram",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "mik-consultation",
        "responseMode": "responseNode",
        "options": {
          "allowedOrigins": "*"
        }
      },
      "id": "webhook-1",
      "name": "Webhook",
