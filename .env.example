# PostgreSQL connection string (requires pgvector extension for RAG embeddings)
# Docker:   postgresql://mik:mik_pass@localhost:5432/mik_platform  (after: docker compose up -d)
# Supabase: Settings → Database → Connection string → URI
# Local:    postgresql://postgres:password@localhost:5432/mik_platform
DATABASE_URL=

PORT=19080

# For RAG embeddings (text-embedding-3-small) and optional chat fallback
OPENAI_API_KEY=

# For RAG chat responses (claude-haiku-4-5-20251001 by default)
ANTHROPIC_API_KEY=

# Optional: override the LLM model used in KB chat (default: claude-haiku-4-5-20251001)
# KB_LLM_MODEL=claude-sonnet-4-6
